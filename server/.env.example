# Required: Sarvam AI API key for speech-to-text
SARVAM_API_KEY=your_sarvam_api_key_here

# Comma-separated list of allowed frontend origins (CORS)
# Example: http://localhost:5173,https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Server port
# Local dev: 3000 (default)
# Docker: 7860 (set automatically by docker-compose.yml)
PORT=3000
